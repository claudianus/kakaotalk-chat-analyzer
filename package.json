{
  "name": "kakaotalk-chat-analyzer",
  "version": "0.11.2",
  "description": "카카오톡 CSV 보내기 → 한글 리포트 → 선택적 임시 공유. npx 한 줄로 실행 가능한 CLI.",
  "type": "module",
  "homepage": "https://claudianus.github.io/kakaotalk-chat-analyzer/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/claudianus/kakaotalk-chat-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/claudianus/kakaotalk-chat-analyzer/issues"
  },
  "bin": {
    "kca": "dist/src/cli.js",
    "kakaotalk-chat-analyzer": "dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "build": "node scripts/bundle-report-css.mjs && tsc -p tsconfig.json",
    "prepack": "node scripts/sync-version.mjs && npm run build",
    "test": "npm run build && node --test dist/test/*.test.js",
    "bench:stream": "npm run build && node scripts/bench-stream.mjs",
    "keyword:diff": "npm run build && node scripts/keyword-diff.mjs",
    "keyword:audit": "npm run build && node scripts/keyword-audit.mjs",
    "report:qa": "npm run build && node scripts/report-visual-qa.mjs",
    "report:qa:serve": "node scripts/qa-serve.mjs",
    "report:viewport": "npm run build && node scripts/report-viewport-check.mjs",
    "report:screenshots": "node scripts/report-viewport-screenshots.mjs",
    "smoke": "node dist/src/cli.js --help",
    "gh:sync-npm-secret": "bash scripts/sync-npm-token-to-gh.sh"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "csv-parse": "^6.2.1",
    "iconv-lite": "^0.7.2",
    "kiwi-nlp": "^0.23.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "open-props": "^1.7.15",
    "playwright": "^1.52.0",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "kakaotalk",
    "chat",
    "analyzer",
    "cli",
    "privacy",
    "npx",
    "korean"
  ],
  "license": "MIT"
}
